# ── Trading mode ──────────────────────────────────────
# sim   = backtest with synthetic data (default)
# paper = paper trading with live Hyperliquid market data
# live  = real trading on Hyperliquid
MODE=sim

# ── Hyperliquid credentials (required for paper + live) ─
HL_WALLET_ADDRESS=0xYourWalletAddressHere
HL_PRIVATE_KEY=0xYourPrivateKeyHere

# ── Base URL (optional, defaults to mainnet) ─────────
# Mainnet: https://api.hyperliquid.xyz
# Testnet: https://api.hyperliquid-testnet.xyz
# HL_BASE_URL=https://api.hyperliquid.xyz

# ── Live trading safety gate ─────────────────────────
# Must be explicitly set to "true" to allow MODE=live
# LIVE_TRADING=true

# ── Logging ──────────────────────────────────────────
# Set to "0" to disable stdout logging
# LOG_STDOUT=1
